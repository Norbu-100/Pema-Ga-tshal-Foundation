generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  createdAt DateTime @default(now())
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  position  String
  message   String
  photoUrl  String?
  createdAt DateTime @default(now())
}

model Donation {
  id               String   @id @default(cuid())
  donorName        String
  address          String
  country          String
  phone            String
  giftTitle        String
  goalPerUnit      Float
  numberOfStudents Int
  totalAmount      Float
  qrScreenshotUrl  String?
  donorPhotoUrl    String?
  status           String   @default("pending")
  adminNote        String?
  createdAt        DateTime @default(now())
}

model DonorPost {
  id          String   @id @default(cuid())
  donorName   String
  giftTitle   String
  amount      Float
  message     String?
  photoUrl    String?
  country     String?
  createdAt   DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hashed password
  createdAt DateTime @default(now())
}
